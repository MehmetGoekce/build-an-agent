{
  // Use this repo's virtual environment so Pylance resolves imports
  // (openai, langchain, ...). Without this you get a cascade of false
  // "unknown type" errors in strict mode.
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // Type-checking strictness lives in pyrightconfig.json (repo root), so
  // that the editor AND command-line `pyright` use the exact same rules.
  // Notebooks are excluded there on purpose — see the README note.
  "python.analysis.autoImportCompletions": true
}
