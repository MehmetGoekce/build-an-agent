# =============================================================
#  build-an-agent — LLM configuration
# =============================================================
#  This tutorial talks to any OpenAI-compatible chat-completions
#  API. The default below is NVIDIA's hosted endpoint: free tier,
#  no GPU, no cloud account. Get a key in ~2 minutes at
#  https://build.nvidia.com  (log in -> pick a model ->
#  "Get API Key"). Keys start with "nvapi-".
#
#  Run it somewhere else? Change only the three LLM_* lines:
#    OpenAI   LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o-mini
#    Ollama   LLM_BASE_URL=http://localhost:11434/v1   LLM_MODEL=llama3.1
#    vLLM     LLM_BASE_URL=http://localhost:8000/v1    LLM_MODEL=<your-model>
#  The tutorial code never hard-codes a provider — see llm.py.
# =============================================================

LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=nvapi-REPLACE-ME
LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Embeddings — used from Part 2 onwards. Same endpoint by default.
EMBED_BASE_URL=https://integrate.api.nvidia.com/v1
EMBED_API_KEY=nvapi-REPLACE-ME
EMBED_MODEL=nvidia/nv-embedqa-e5-v5
